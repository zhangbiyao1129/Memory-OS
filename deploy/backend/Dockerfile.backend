FROM golang:1.25-bookworm AS build
WORKDIR /src
ARG BUILD_VERSION=0.9.0-dev
ARG BUILD_COMMIT=unknown
ARG BUILD_TIME=unknown
ARG BUILD_DIRTY=unknown
ARG GOPROXY=https://goproxy.cn,direct
ARG NO_PROXY=localhost,127.0.0.1,postgres,redis,qdrant,memory-api,memory-web,memory-mcp,memory-llm-mock
ENV GOPROXY=${GOPROXY}
ENV NO_PROXY=${NO_PROXY}
ENV no_proxy=${NO_PROXY}
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ ./cmd/
COPY internal/ ./internal/
COPY migrations/ ./migrations/
RUN go build -ldflags "-X memory-os/internal/buildinfo.Version=${BUILD_VERSION} -X memory-os/internal/buildinfo.Commit=${BUILD_COMMIT} -X memory-os/internal/buildinfo.BuildTime=${BUILD_TIME} -X memory-os/internal/buildinfo.Dirty=${BUILD_DIRTY}" -o /out/memory-api ./cmd/memory-api \
 && go build -ldflags "-X memory-os/internal/buildinfo.Version=${BUILD_VERSION} -X memory-os/internal/buildinfo.Commit=${BUILD_COMMIT} -X memory-os/internal/buildinfo.BuildTime=${BUILD_TIME} -X memory-os/internal/buildinfo.Dirty=${BUILD_DIRTY}" -o /out/memory-worker ./cmd/memory-worker \
 && go build -ldflags "-X memory-os/internal/buildinfo.Version=${BUILD_VERSION} -X memory-os/internal/buildinfo.Commit=${BUILD_COMMIT} -X memory-os/internal/buildinfo.BuildTime=${BUILD_TIME} -X memory-os/internal/buildinfo.Dirty=${BUILD_DIRTY}" -o /out/memory-mcp ./cmd/memory-mcp

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=build /out/memory-api /usr/local/bin/memory-api
COPY --from=build /out/memory-worker /usr/local/bin/memory-worker
COPY --from=build /out/memory-mcp /usr/local/bin/memory-mcp
EXPOSE 18081 18082
