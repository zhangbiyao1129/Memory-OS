APP_ENV=production
ENABLE_DEV_ENDPOINTS=false

MEMORY_WEB_ADDR=:18080
MEMORY_API_ADDR=:18081
MEMORY_MCP_ADDR=:18082

POSTGRES_DSN=postgres://memory_os:replace-me@postgres:5432/memory_os?sslmode=disable
REDIS_ADDR=redis:6379
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=memory_os
ARCHIVE_DIR=/data/memory-os
NO_PROXY=localhost,127.0.0.1,postgres,redis,qdrant,memory-api,memory-web,memory-mcp
no_proxy=localhost,127.0.0.1,postgres,redis,qdrant,memory-api,memory-web,memory-mcp

LLM_BASE_URL=http://example.local:8000
LLM_API_KEY=replace-me
LLM_MODEL=MiniMax-M2.7
EMBEDDING_MODEL=bge-m3
RERANK_MODEL=bge-reranker-v2-m3

# Secret 明文只在本机 MCP 加解密，服务端不再持有任何解密 key。
# 本机 MCP 相关变量（在运行 memory-mcp-local 的机器上设置，服务端无需）：
#   MEMORY_OS_API_URL=http://127.0.0.1:18081
#   MEMORY_OS_TOKEN=<PAT>
#   MEMORY_OS_SECRET_KEY_PATH=~/.config/memory-os/secret-device-key.json （目录 700 / 文件 600）

WORKER_CONCURRENCY=1
ARCHIVE_BATCH_INTERVAL=30m
EMBED_BATCH_SIZE=8
RERANK_BATCH_SIZE=8
MAX_PARALLEL_INDEX_JOBS=1
MAX_TURN_EVENT_BYTES=256KB
MAX_TOOL_OUTPUT_BYTES=64KB
